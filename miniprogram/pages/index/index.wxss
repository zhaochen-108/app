.user-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
}

.section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
}

.btn-add {
  color: #4A90D9;
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid #4A90D9;
  border-radius: 30rpx;
}

.child-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.child-color {
  width: 16rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.child-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.child-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.child-courses {
  font-size: 24rpx;
  color: #999;
}

.child-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 10rpx;
}

.color-dot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.color-dot.selected {
  border-color: #333;
  transform: scale(1.15);
}

/* 弹窗按钮 */
.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  margin: 0;
}
