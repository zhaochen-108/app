<view class="container">
  <!-- 组信息 -->
  <view class="card group-header">
    <text class="group-name">{{group.name}}</text>
    <view class="invite-section">
      <text class="invite-label">邀请码：</text>
      <text class="invite-code">{{group.inviteCode}}</text>
      <text class="copy-btn" bindtap="copyInviteCode">复制</text>
    </view>
  </view>

  <!-- 成员列表 -->
  <view class="section">
    <text class="section-title">成员 ({{group.members.length}})</text>
    <view class="member-list card">
      <view class="member-item" wx:for="{{group.members}}" wx:key="userId">
        <text class="member-name">{{item.nickName}}</text>
        <text class="member-role" wx:if="{{item.role === 'owner'}}">组长</text>
      </view>
    </view>
  </view>

  <!-- 组内孩子 -->
  <view class="section">
    <text class="section-title">宝贝们 ({{group.children.length}})</text>
    <view class="children-list">
      <view class="child-tag" wx:for="{{group.children}}" wx:key="childId" style="border-color: {{item.color || '#4A90D9'}}">
        <view class="tag-dot" style="background: {{item.color || '#4A90D9'}}"></view>
        <text>{{item.childName}}</text>
        <text class="tag-owner">（{{item.parentName}}）</text>
      </view>
    </view>

    <!-- 添加自己的孩子到组 -->
    <view class="add-child-section" wx:if="{{unaddedChildren.length > 0}}">
      <text class="sub-title">添加我的宝贝到组</text>
      <view class="child-tag addable" wx:for="{{unaddedChildren}}" wx:key="_id" bindtap="addChildToGroup" data-child="{{item}}">
        <view class="tag-dot" style="background: {{item.color}}"></view>
        <text>{{item.name}}</text>
        <text class="tag-add">+ 加入</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="btn-primary" bindtap="goToMergeView">📊 查看合并课程表</button>
    <button class="btn-danger leave-btn" bindtap="leaveGroup" wx:if="{{!isOwner}}">退出家庭组</button>
    <button class="btn-danger leave-btn" bindtap="deleteGroup" wx:if="{{isOwner}}">解散家庭组</button>
  </view>
</view>
