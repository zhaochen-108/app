.group-header {
  text-align: center;
  padding: 40rpx 30rpx;
}

.group-name {
  font-size: 38rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

/* 邀请好友分享按钮 */
.btn-share {
  width: 80%;
  margin: 20rpx auto 0;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(79, 172, 254, 0.3);
}

.btn-share::after {
  border: none;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
  padding: 0 10rpx;
}

.member-list {
  padding: 10rpx 30rpx;
}

.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-item:last-child {
  border-bottom: none;
}

.member-name {
  font-size: 28rpx;
}

.member-role {
  font-size: 22rpx;
  color: #fa8c16;
  background: #fff7e6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 孩子标签 */
.children-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 10rpx;
}

.child-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tag-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.tag-owner {
  font-size: 22rpx;
  color: #999;
}

.tag-add {
  color: #FF7B3A;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.child-tag.addable {
  border-style: dashed;
  border-color: #ccc;
}

.add-child-section {
  margin-top: 20rpx;
  padding: 0 10rpx;
}

.sub-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

/* 操作按钮 */
.action-section {
  margin-top: 50rpx;
  padding: 0 10rpx 40rpx;
}

.action-section button {
  margin-bottom: 20rpx;
}

.leave-btn {
  margin-top: 10rpx;
}
