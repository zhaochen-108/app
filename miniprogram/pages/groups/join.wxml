<view class="container theme-{{theme}}">
  <!-- 加载中 -->
  <view class="join-card card" wx:if="{{status === 'loading'}}">
    <text class="join-icon">⏳</text>
    <text class="join-title">加载中...</text>
  </view>

  <!-- 确认加入 -->
  <view class="join-card card" wx:if="{{status === 'confirming'}}">
    <text class="join-icon">👨‍👩‍👧‍👦</text>
    <text class="join-title">邀请你加入</text>
    <text class="join-group-name">「{{groupName}}」</text>
    <text class="join-desc">加入后可以一起查看孩子们的课程安排，发现共同空闲时间</text>
    <button class="btn-join" bindtap="confirmJoin">加入约玩圈</button>
    <text class="link-text" bindtap="goHome">暂不加入，去首页看看</text>
  </view>

  <!-- 加入中 -->
  <view class="join-card card" wx:if="{{status === 'joining'}}">
    <text class="join-icon">⏳</text>
    <text class="join-title">正在加入...</text>
  </view>

  <!-- 加入成功 -->
  <view class="join-card card" wx:if="{{status === 'success'}}">
    <text class="join-icon">🎉</text>
    <text class="join-title">加入成功</text>
    <text class="join-desc">你已成功加入「{{groupName}}」</text>
    <button class="btn-join" bindtap="goToGroups">去约玩圈看看</button>
  </view>

  <!-- 出错 -->
  <view class="join-card card" wx:if="{{status === 'error'}}">
    <text class="join-icon">😅</text>
    <text class="join-title">{{errorMsg}}</text>
    <button class="btn-join" bindtap="goHome">去首页</button>
  </view>
</view>
