.merge-header {
  text-align: center;
  margin-bottom: 16rpx;
}

.merge-title {
  font-size: 32rpx;
  font-weight: bold;
}

/* 图例 */
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.legend-dot.free-dot {
  background: #52c41a;
  opacity: 0.3;
  border: 2rpx solid #52c41a;
}

.legend-name {
  font-size: 24rpx;
  color: #666;
}

/* 星期选择 */
.weekday-tabs {
  display: flex;

  margin-bottom: 16rpx;
}

.weekday-tab {
  flex: 1;
  padding: 10rpx 0;
  margin: 0 4rpx;
  text-align: center;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.weekday-tab.active {
  background: #FF7B3A;
  color: #fff;
}

/* 时间轴 */
.timeline-container {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.timeline {
  display: flex;
  position: relative;
  min-height: 1560rpx; /* 13小时 * 120rpx */
}

.time-column {
  width: 100rpx;
  flex-shrink: 0;
  border-right: 2rpx solid #f0f0f0;
}

.time-label {
  height: 120rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  padding-top: 4rpx;
}

.schedule-column {
  flex: 1;
  position: relative;
}

/* 空闲时段 */
.free-slot {
  position: absolute;
  left: 0;
  right: 0;
  background: rgba(82, 196, 26, 0.1);
  border-left: 4rpx solid #52c41a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.free-text {
  font-size: 22rpx;
  color: #52c41a;
}

/* 课程块 */
.course-block {
  position: absolute;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  overflow: hidden;
  box-sizing: border-box;
  min-height: 50rpx;
}

.course-block-name {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;

}

.course-block-time {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.course-block-child {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 空闲摘要 */
.free-summary {
  padding: 24rpx 30rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.free-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.free-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f6ffed;
  border-radius: 8rpx;
  border: 2rpx solid #b7eb8f;
}

.free-time {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.free-duration {
  font-size: 24rpx;
  color: #52c41a;
}
