<view class="container theme-{{theme}}">
  <view class="brand">
    <view class="brand-title">爱玩工程师</view>
    <view class="brand-subtitle">让带娃更有趣</view>
  </view>

  <view class="feature-grid">
    <view class="feature-card {{item.active ? '' : 'disabled'}}"
          wx:for="{{features}}" wx:key="id"
          bindtap="onTapFeature" data-id="{{item.id}}">
      <view class="feature-icon">
        <image wx:if="{{item.icon}}" src="{{item.icon}}" mode="aspectFit" />
        <view wx:else class="feature-icon-placeholder">?</view>
      </view>
      <view class="feature-name">{{item.name}}</view>
      <view class="feature-desc">{{item.desc}}</view>
    </view>
  </view>
</view>