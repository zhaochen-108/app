/* 隐藏 Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1000px;
  height: 920px;
}

/* 加载状态 */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #FF7B3A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* 预览区域 */
.preview-area {
  padding: 30rpx;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 操作按钮 */
.action-buttons {
  padding: 30rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.btn-save {
  background: #FF7B3A;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 36rpx 60rpx;
  border: none;
  line-height: 1.5;
}

.btn-save::after {
  border: none;
}

.btn-back {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 0;
}
