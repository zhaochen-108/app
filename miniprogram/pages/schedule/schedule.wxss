.child-header {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.child-name {
  font-size: 34rpx;
  font-weight: bold;
}

/* 星期选择 */
.weekday-tabs {
  display: flex;

  margin-bottom: 20rpx;
}

.weekday-tab {
  flex: 1;
  padding: 12rpx 0;
  margin: 0 4rpx;
  text-align: center;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.weekday-tab.active {
  background: #FF7B3A;
  color: #fff;
}

/* 课程列表 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-left-width: 8rpx;
  border-left-style: solid;
}

.schedule-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  margin-right: 24rpx;
}

.time-start, .time-end {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.time-sep {
  font-size: 20rpx;
  color: #ccc;
  margin: 4rpx 0;
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.course-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.course-location {
  font-size: 24rpx;
  color: #999;
}

.schedule-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

/* 浮动添加按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #FF7B3A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
}

.fab text {
  color: #fff;
  font-size: 56rpx;
  line-height: 1;
}

/* 上学时间按钮 */
.child-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.school-time-btn, .share-week-btn {
  font-size: 24rpx;
  color: #FF7B3A;
  border: 2rpx solid #FF7B3A;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

/* 上学时间弹窗 */
.school-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.school-tip {
  margin-top: 20rpx;
  padding: 12rpx 16rpx;
  background: #fff7e6;
  border-radius: 8rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #fa8c16;
}
