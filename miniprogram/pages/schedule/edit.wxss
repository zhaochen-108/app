.picker-value {
  color: #333;
  line-height: 1.5;
}

.button-group {
  margin-top: 40rpx;
  padding: 0 30rpx;
}

.save-btn {
  width: 100%;
}

/* 智能输入 */
.smart-input-card {
  background: #f0f5ff;
  border: 2rpx solid #4A90D9;
}

.smart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.smart-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A90D9;
}

.smart-hint {
  font-size: 22rpx;
  color: #999;
}

.smart-input {
  background: #fff;
  margin-bottom: 16rpx;
}

.btn-smart {
  background: #4A90D9;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 14rpx 0;
  border: none;
}

.btn-smart::after {
  border: none;
}
