<view class="container theme-{{theme}}">
  <!-- 用户信息 -->
  <view class="card profile-card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="profile-info">
      <text class="nickname">{{userInfo.nickName || '未设置昵称'}}</text>
    </view>
  </view>

  <!-- 主题切换 -->
  <view class="card">
    <view class="setting-item-title">主题风格</view>
    <view class="theme-picker">
      <view class="theme-option {{theme === 'blue' ? 'active' : ''}}" bindtap="switchTheme" data-theme="blue">
        <view class="theme-preview blue-preview"></view>
        <text class="theme-name">简约蓝</text>
      </view>
      <view class="theme-option {{theme === 'cute' ? 'active' : ''}}" bindtap="switchTheme" data-theme="cute">
        <view class="theme-preview cute-preview"></view>
        <text class="theme-name">甜橙可爱</text>
      </view>
    </view>
  </view>

  <!-- 设置昵称 -->
  <view class="card">
    <view class="setting-item" bindtap="editNickname">
      <text class="setting-label">修改昵称</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="card stats-card">
    <view class="stat-item">
      <text class="stat-num">{{childCount}}</text>
      <text class="stat-label">宝贝</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{courseCount}}</text>
      <text class="stat-label">课程</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{groupCount}}</text>
      <text class="stat-label">约玩圈</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card">
    <view class="setting-item">
      <text class="setting-label">版本</text>
      <text class="setting-value">1.0.0</text>
    </view>
  </view>

  <!-- 昵称编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="noop">
      <view class="modal-title">修改昵称</view>
      <view class="form-item">
        <input class="form-input" placeholder="请输入昵称" value="{{newNickname}}" bindinput="onNicknameInput" />
      </view>
      <view class="modal-buttons">
        <button class="btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn-primary" bindtap="saveNickname">保存</button>
      </view>
    </view>
  </view>
</view>
