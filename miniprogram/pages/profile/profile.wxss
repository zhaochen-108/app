.profile-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.profile-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
}

/* 统计 */
.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 10rpx;
}

.setting-label {
  font-size: 30rpx;
}

.setting-value {
  font-size: 28rpx;
  color: #999;
}

.setting-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 弹窗按钮 */
.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  margin: 0;
}

.setting-item-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
